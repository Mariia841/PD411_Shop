@model List<PD411_Shop.ViewModels.CartIndexVM>

<div class="container mt-5">
    <h2>Ваш кошик</h2>

    @if (Model.Any())
    {
        <table class="table align-middle">
            <thead class="table-light">
                <tr>
                    <th>Товар</th>
                    <th>Ціна</th>
                    <th class="text-center">Кількість</th>
                    <th>Сума</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="~/images/@(item.Image ?? "default.jpg")" alt="@item.Name" style="width: 50px; height: 50px; object-fit: contain;" class="me-3">
                                <span>@item.Name</span>
                            </div>
                        </td>
                        <td>@item.Price $</td>
                        <td>
                            <div class="d-flex justify-content-center align-items-center gap-2">
                                <a asp-action="Decrement" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-secondary">-</a>
                                <span class="fw-bold">@item.Count</span>
                                <a asp-action="Increment" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-secondary">+</a>
                            </div>
                        </td>
                        <td>@item.TotalPrice $</td>
                        <td class="text-end">
                            <a asp-action="Remove" asp-route-id="@item.ProductId" class="text-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row mt-4">
            <div class="col-md-6 offset-md-6">
                <div class="card p-3 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4>Загальна сума:</h4>
                        <h3 class="text-primary">@Model.Sum(x => x.TotalPrice) $</h3>
                    </div>
                    <hr>
                    <button class="btn btn-success btn-lg w-100">Оформити замовлення</button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
            <p class="lead mt-3">Ваш кошик порожній</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Повернутися до магазину</a>
        </div>
    }
</div>