@model PD411_Shop.ViewModels.CategoryVM

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow p-4 bg-light">
            <h2 class="text-center">Додати категорію</h2>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Введіть назву..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Зберегти</button>
                    <a asp-action="Index" class="btn btn-secondary w-100">Назад</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}